# Port the Express server listens on. Security group only allows 3001 from
# the da-platform private IP, so changing this requires an SG update too.
PORT=3001

# Shared secret. da-platform sends this in X-API-Key on every request.
# Generate via: openssl rand -hex 32
PDF_SERVICE_API_KEY=

# S3 (re-uses dealer-addendums bucket — same keys main app uses).
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=dealer-addendums

# How long to keep finished jobs in the in-memory store before garbage
# collection. Default 30 minutes — long enough for the polling client to
# pick up the S3 key, short enough to bound memory.
JOB_TTL_MINUTES=30
